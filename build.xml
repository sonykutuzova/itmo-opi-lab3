             todir="${scp.user}:${scp.password}@${scp.host}:${scp.dir}"
             port="${scp.port}"
             trust="true"
             failonerror="true"
             verbose="true"/>
        <echo message="Файл успешно доставлен!"/>
    </target>-->


    <!-- 14. Цель HISTORY -->
    <!-- 14. Цель HISTORY (Бронебойная версия) -->
    <target name="history" description="Откат до рабочей версии">
        <!-- 1. Пробуем скомпилировать -->
        <exec executable="ant.bat" resultproperty="res">
            <arg value="compile"/>
        </exec>

        <condition property="is.ok">
            <equals arg1="${res}" arg2="0"/>
        </condition>

        <!-- 2. Если всё ок - финиш -->
        <antcall target="-history-win"/>
        <!-- 3. Если нет - откат -->
        <antcall target="-history-retry"/>
    </target>

    <target name="-history-win" if="is.ok">
        <echo message="ПОБЕДА! Рабочая версия найдена."/>
    </target>

    <target name="-history-retry" unless="is.ok">
        <echo message="Код сломан. Откатываемся..."/>
        <exec executable="git" failonerror="true">
            <arg value="checkout"/>
            <arg value="HEAD~1"/>
        </exec>
        <!-- ВНИМАНИЕ: вызываем саму цель history, она точно есть в старых файлах -->
        <antcall target="history"/>
    </target>
</project>